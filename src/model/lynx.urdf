<?xml version="1.0"?>
<robot name="a4wd1">

  <!-- =========================================================
       Coordinate convention (common robotics)
         x = forward, y = left, z = up
       ========================================================= -->

  <!-- =========================
       BASE LINK (CHASSIS)
       ========================= -->
  <link name="base_link">
    <!-- Chassis box (proxy geometry) -->
    <visual>
      <!-- Chassis center height: wheel_radius + chassis_height/2
           = 0.0625 + 0.102/2 = 0.1135 -->
      <origin xyz="0 0 0.1135" rpy="0 0 0"/>
      <geometry>
        <box size="0.248 0.203 0.102"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0.1135" rpy="0 0 0"/>
      <geometry>
        <box size="0.248 0.203 0.102"/>
      </geometry>
    </collision>

    <!-- Rough inertial properties (good enough to start sim + RL).
         You can refine later. -->
    <inertial>
      <origin xyz="0 0 0.1135" rpy="0 0 0"/>
      <mass value="1.2"/>
      <inertia ixx="0.02" ixy="0.0" ixz="0.0"
               iyy="0.02" iyz="0.0"
               izz="0.02"/>
    </inertial>
  </link>

  <!-- =========================
       WHEELS (4 cylinder links)
       Note: URDF cylinder axis is along Z by default.
             We rotate each cylinder by +90 deg about X (rpy = 1.5708 0 0)
             so the wheel axle aligns with +Y (left-right).
       ========================= -->

  <link name="wheel_fl">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0625" length="0.060"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0625" length="0.060"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <link name="wheel_fr">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0625" length="0.060"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0625" length="0.060"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <link name="wheel_rl">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0625" length="0.060"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0625" length="0.060"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <link name="wheel_rr">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0625" length="0.060"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0625" length="0.060"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <!-- =========================
       WHEEL JOINTS (revolute)
       Wheelbase assumed 0.25 m -> half = 0.125
       Track width given 0.2775 m -> half = 0.13875
       Wheel centers at z = wheel_radius = 0.0625
       ========================= -->

  <joint name="joint_fl" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_fl"/>
    <origin xyz="0.125 0.13875 0.0625" rpy="0 0 0"/>
    <!-- axle along Y -->
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="50" lower="-1000" upper="1000"/>
  </joint>

  <joint name="joint_fr" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_fr"/>
    <origin xyz="0.125 -0.13875 0.0625" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="50" lower="-1000" upper="1000"/>
  </joint>

  <joint name="joint_rl" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_rl"/>
    <origin xyz="-0.125 0.13875 0.0625" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="50" lower="-1000" upper="1000"/>
  </joint>

  <joint name="joint_rr" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_rr"/>
    <origin xyz="-0.125 -0.13875 0.0625" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="50" lower="-1000" upper="1000"/>
  </joint>

  <!-- =========================
       RPLIDAR MOUNT FRAME
       You requested: top of chassis, toward the front, slightly left.
       We place a fixed "frame" (link) there.

       Chassis top is at:
         base_link center z = 0.1135
         chassis height/2 = 0.051
         top z ≈ 0.1135 + 0.051 = 0.1645

       Mount z = 0.18 puts it slightly above the top surface.
       ========================= -->

  <link name="rplidar_link"/>

  <joint name="rplidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rplidar_link"/>
    <!-- x forward, y left, z up -->
    <origin xyz="0.10 0.06 0.18" rpy="0 0 0"/>
  </joint>

</robot>